if {[lsearch [namespace children] ::tcltest] == -1} {
    package require tcltest
}
if {[llength [info commands test]] == 0} {
    namespace import ::tcltest::test
}

::tcltest::loadTestedCommands

namespace eval tclreadline::test {
    # Only a sample test! Does not test all build-info commands.
    test build-info-1.1 {build-info command} -body {
        tclreadline::build-info
    } -result * -match glob
}


::tcltest::cleanupTests
namespace delete tclreadline::test
return
